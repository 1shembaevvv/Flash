generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Card {
  id Int @id @default(autoincrement())
  question String
  answer String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Progress {
  id Int @id @default(autoincrement())
  progress Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}